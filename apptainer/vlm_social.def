Bootstrap: docker
From: ubuntu:22.04

%labels
    Author zonghuan
    Description VLM Social analysis environment with video stats and sentence-transformers

%help
    Build from the apptainer directory:
        cd apptainer
        apptainer build gesbench.sif gesbench.def

    Example usage:
        apptainer exec --bind ..:/workspace gesbench.sif \
            python /workspace/dataset/dataset_info.py /path/to/videos /path/to/output

        apptainer exec --bind ..:/workspace gesbench.sif \
            python /workspace/experiments/analysis/main.py

%files
    requirements.txt /opt/requirements.txt

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export PIP_NO_CACHE_DIR=1
    export MPLCONFIGDIR=/tmp/matplotlib
    export XDG_CACHE_HOME=/tmp

%post
    export DEBIAN_FRONTEND=noninteractive

    # Verify requirements.txt was copied by %files
    if [ ! -f /opt/requirements.txt ]; then
        echo "ERROR: /opt/requirements.txt not found."
        echo "Make sure to build from the apptainer/ directory:"
        echo "    cd apptainer && apptainer build gesbench.sif gesbench.def"
        exit 1
    fi

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        ffmpeg \
        fonts-dejavu-core \
        git \
        libglib2.0-0 \
        libgomp1 \
        libsm6 \
        libxext6 \
        libxrender1 \
        python3 \
        python3-pip \
        python3-venv
    rm -rf /var/lib/apt/lists/*

    ln -sf /usr/bin/python3 /usr/local/bin/python
    python -m pip install --upgrade pip setuptools wheel
    python -m pip install -r /opt/requirements.txt

    mkdir -p /workspace /tmp/matplotlib

%runscript
    exec "$@"

%test
    python -c "import cv2, matplotlib, numpy, sentence_transformers, sklearn, torch"
