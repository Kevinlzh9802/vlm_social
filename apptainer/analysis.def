Bootstrap: docker
From: ubuntu:22.04

%labels
    Author anonym
    Description Lightweight environment for experiments/analysis/main.py (clip-to-final cosine similarity)

%help
    Build from the apptainer directory:
        cd apptainer
        apptainer build analysis.sif analysis.def

    Example usage (bind the repo root as /workspace):
        apptainer exec --bind ..:/workspace analysis.sif \
            python /workspace/experiments/analysis/main.py

        apptainer exec --bind ..:/workspace analysis.sif \
            python /workspace/experiments/analysis/main.py --results-root /workspace/results/qwen2.5

%files
    requirements_analysis.txt /opt/requirements_analysis.txt

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export PIP_NO_CACHE_DIR=1
    export MPLCONFIGDIR=/tmp/matplotlib
    export XDG_CACHE_HOME=/tmp
    export HF_HOME=/tmp/huggingface

%post
    export DEBIAN_FRONTEND=noninteractive

    # Verify requirements file was copied by %files
    if [ ! -f /opt/requirements_analysis.txt ]; then
        echo "ERROR: /opt/requirements_analysis.txt not found."
        echo "Make sure to build from the apptainer/ directory:"
        echo "    cd apptainer && apptainer build analysis.sif analysis.def"
        exit 1
    fi

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        fonts-dejavu-core \
        git \
        libglib2.0-0 \
        libgomp1 \
        python3 \
        python3-pip \
        python3-venv
    rm -rf /var/lib/apt/lists/*

    ln -sf /usr/bin/python3 /usr/local/bin/python
    python -m pip install --upgrade pip setuptools wheel
    python -m pip install -r /opt/requirements_analysis.txt

    mkdir -p /workspace /tmp/matplotlib /tmp/huggingface

%runscript
    exec python "$@"

%test
    python -c "import matplotlib, sentence_transformers, sklearn, torch; print('All imports OK')"
